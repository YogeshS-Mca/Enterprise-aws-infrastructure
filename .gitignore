# Terraform working directory
.terraform/

# Terraform state files
*.tfstate
*.tfstate.*

# Variable files (may contain secrets)
terraform.tfvars
*.auto.tfvars

# Terraform crash logs
crash.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform lock file (keep if working in a team)
# .terraform.lock.hcl

# VS Code settings
.vscode/

# macOS files
.DS_Store

# Windows files
Thumbs.db
desktop.ini

# SSH Private Keys
keys/
*.pem